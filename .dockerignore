# ============================================
# DOCKER IGNORE FILE
# ============================================
# This file specifies which files and directories should be excluded
# from the Docker build context. This speeds up builds and reduces
# image size by excluding unnecessary files.

# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build output
dist
build
.next
out

# Testing
coverage
.nyc_output
*.test.js
*.spec.js
__tests__
__mocks__

# Development files
.env.local
.env.development
.env.test
*.local

# IDE and Editor
.vscode
.idea
*.swp
*.swo
*~
.DS_Store

# Version control
.git
.gitignore
.gitattributes

# CI/CD
.github
.gitlab-ci.yml
.travis.yml
.circleci

# Documentation
README.md
CHANGELOG.md
LICENSE
docs

# Docker files (we copy these explicitly when needed)
Dockerfile*
docker-compose*.yml
.dockerignore

# Logs
logs
*.log

# OS files
Thumbs.db
.DS_Store

# Temporary files
tmp
temp
*.tmp
